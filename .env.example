# Copy this file to .env and fill in your local values
# .env is gitignored — never commit it

# Database
DB_URL=jdbc:postgresql://localhost:5432/live-sports-streaks
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# TheSportsDB — get your key at https://www.thesportsdb.com/
# Free test key is "3" (rate-limited); use a Patreon key for production
THESPORTSDB_KEY=your_key_here
