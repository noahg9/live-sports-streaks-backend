# Copy this file to .env and fill in your local values
# .env is gitignored — never commit it

# Database
DB_URL=jdbc:postgresql://localhost:5432/live-sports-streaks
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# api-sports.io — single key used across all sport APIs
# Get your key at https://dashboard.api-sports.io
API_SPORTS_KEY=your_api_key_here

# api-sports.io sport URLs (defaults already set in application.properties — only override if needed)
# API_FOOTBALL_URL=https://v3.football.api-sports.io
# API_BASKETBALL_URL=https://v1.basketball.api-sports.io
# API_NBA_URL=https://v2.nba.api-sports.io
# API_AFL_URL=https://v1.afl.api-sports.io
# API_BASEBALL_URL=https://v1.baseball.api-sports.io
# API_HOCKEY_URL=https://v1.hockey.api-sports.io
# API_RUGBY_URL=https://v1.rugby.api-sports.io
# API_HANDBALL_URL=https://v1.handball.api-sports.io
# API_VOLLEYBALL_URL=https://v1.volleyball.api-sports.io
# API_MMA_URL=https://v1.mma.api-sports.io
# API_NFL_URL=https://v1.american-football.api-sports.io
# API_FORMULA1_URL=https://v1.formula-1.api-sports.io
